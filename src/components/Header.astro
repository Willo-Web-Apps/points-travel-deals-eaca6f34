---
<header class="sticky top-0 z-50 border-b border-surface-200/20 bg-surface-50/80 backdrop-blur-xl">
  <nav class="max-w-7xl mx-auto px-5 sm:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <!-- Amber diamond mark -->
      <span class="w-7 h-7 rounded-md bg-brand-500 flex items-center justify-center shrink-0 group-hover:bg-brand-400 transition-colors duration-200">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M7 1L13 7L7 13L1 7L7 1Z" fill="oklch(0.13 0.025 240)" stroke="none"/>
        </svg>
      </span>
      <span class="text-lg font-semibold tracking-tight text-surface-950 font-display" style="letter-spacing: -0.01em;">Pointara</span>
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#how-it-works" class="text-sm font-medium text-surface-800 hover:text-surface-950 transition-colors duration-150">How It Works</a>
      <a href="#features" class="text-sm font-medium text-surface-800 hover:text-surface-950 transition-colors duration-150">Features</a>
      <a href="#pricing" class="text-sm font-medium text-surface-800 hover:text-surface-950 transition-colors duration-150">Pricing</a>
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a href="#pricing" class="hidden sm:block text-sm font-medium text-surface-800 hover:text-surface-950 transition-colors duration-150">Sign in</a>
      <a href="#cta" class="text-sm font-semibold bg-brand-500 text-surface-50 px-5 py-2.5 rounded-full hover:bg-brand-400 transition-colors duration-200 shadow-sm" style="color: oklch(0.13 0.025 240);">
        Get early access
      </a>
    </div>
  </nav>
</header>
