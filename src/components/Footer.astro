---
const year = new Date().getFullYear();
---
<footer class="border-t border-surface-200/15 py-12 mt-auto bg-surface-50">
  <div class="max-w-7xl mx-auto px-5 sm:px-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">

      <!-- Brand -->
      <div class="flex items-center gap-2.5">
        <span class="w-6 h-6 rounded bg-brand-500 flex items-center justify-center shrink-0">
          <svg width="12" height="12" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7 1L13 7L7 13L1 7L7 1Z" fill="oklch(0.13 0.025 240)" stroke="none"/>
          </svg>
        </span>
        <span class="text-base font-semibold text-surface-950 font-display">Redeemly</span>
      </div>

      <!-- Links -->
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        <a href="#how-it-works" class="text-sm text-surface-800 hover:text-surface-950 transition-colors duration-150">How It Works</a>
        <a href="#features" class="text-sm text-surface-800 hover:text-surface-950 transition-colors duration-150">Features</a>
        <a href="#pricing" class="text-sm text-surface-800 hover:text-surface-950 transition-colors duration-150">Pricing</a>
        <a href="/blog" class="text-sm text-surface-800 hover:text-surface-950 transition-colors duration-150">Blog</a>
        <a href="mailto:hello@redeemly.com" class="text-sm text-surface-800 hover:text-surface-950 transition-colors duration-150">Contact</a>
      </div>

      <!-- Copyright -->
      <p class="text-sm text-surface-800/60">&copy; {year} Redeemly. All rights reserved.</p>
    </div>

    <!-- Tagline -->
    <p class="mt-6 text-xs text-surface-800/40 font-display italic">
      Your points. Your perfect deal. Every day.
    </p>
  </div>
</footer>
