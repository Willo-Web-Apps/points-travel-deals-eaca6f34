---
import Base from '../layouts/Base.astro';
---
<Base
  title="Redeemly — Your Points, One Perfect Deal, Every Single Day"
  description="Redeemly reads your exact loyalty balances, runs the transfer math, and surfaces the one best trip you can book right now. No searching required."
>

  <!-- ═══════════════════════════════════════════════════════════════════
       HERO — Asymmetric layout, deal card as centrepiece
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-[100svh] flex items-center overflow-hidden grain-overlay" style="background-color: oklch(0.13 0.025 240);">

    <!-- Layered gradient lighting -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <!-- Primary amber glow — upper left -->
      <div style="
        position: absolute;
        top: -10%;
        left: -5%;
        width: 65%;
        height: 70%;
        background: radial-gradient(ellipse at 30% 30%, oklch(0.72 0.16 70 / 0.12) 0%, transparent 65%);
        filter: blur(2px);
      "></div>
      <!-- Deep blue sweep — lower right -->
      <div style="
        position: absolute;
        bottom: -15%;
        right: -10%;
        width: 70%;
        height: 75%;
        background: radial-gradient(ellipse at 70% 70%, oklch(0.28 0.06 240 / 0.35) 0%, transparent 60%);
      "></div>
      <!-- Subtle conic sweep across centre -->
      <div style="
        position: absolute;
        inset: 0;
        background: conic-gradient(from 200deg at 60% 45%, oklch(0.20 0.04 240 / 0.4) 0deg, transparent 60deg, transparent 300deg, oklch(0.20 0.04 240 / 0.4) 360deg);
      "></div>
      <!-- Horizon glow at bottom to bleed into next section -->
      <div style="
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 180px;
        background: linear-gradient(to bottom, transparent, oklch(0.13 0.025 240));
      "></div>
    </div>

    <!-- Content grid -->
    <div class="relative z-10 w-full max-w-7xl mx-auto px-5 sm:px-8 py-24 md:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-10 items-center">

        <!-- Left: Headline + CTA -->
        <div class="max-w-xl">
          <!-- Kicker -->
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/8 mb-7 animate-fade-in" style="background-color: oklch(0.72 0.16 70 / 0.08);">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse"></span>
            <span class="text-xs font-medium tracking-wide uppercase" style="color: oklch(0.82 0.12 72);">Daily award deals — live now</span>
          </div>

          <!-- Headline — DM Serif italic for editorial luxury -->
          <h1 class="font-display text-5xl sm:text-6xl lg:text-[4.25rem] leading-[1.05] tracking-tight animate-slide-up delay-100" style="color: oklch(0.96 0.006 75); font-style: italic; font-weight: 400;">
            Your Points,<br>
            <span style="color: oklch(0.78 0.14 70);">One Perfect Deal,</span><br>
            Every Single Day
          </h1>

          <!-- Sub -->
          <p class="mt-6 text-lg leading-relaxed animate-slide-up delay-200" style="color: oklch(0.70 0.018 235); max-width: 38ch;">
            Redeemly reads your exact balances, runs the transfer math, and surfaces the one best trip you can book right now — no searching required.
          </p>

          <!-- CTAs -->
          <div class="mt-10 flex flex-col sm:flex-row gap-3 animate-slide-up delay-300">
            <a href="#cta" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]"
               style="background-color: oklch(0.72 0.16 70); color: oklch(0.13 0.025 240); box-shadow: 0 4px 24px oklch(0.72 0.16 70 / 0.35);">
              Claim my early access
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full font-medium text-sm border transition-colors duration-200"
               style="border-color: oklch(0.96 0.006 75 / 0.15); color: oklch(0.88 0.010 75); background: oklch(0.96 0.006 75 / 0.04);">
              See how it works
            </a>
          </div>

          <!-- Micro proof -->
          <p class="mt-5 text-xs animate-fade-in delay-400" style="color: oklch(0.55 0.015 235);">
            No credit card required · Connects Chase, Amex, Citi, airlines &amp; hotels
          </p>
        </div>

        <!-- Right: Today's Deal card -->
        <div class="flex justify-center lg:justify-end animate-slide-right delay-300">
          <div class="w-full max-w-sm relative">
            <!-- Card ambient glow layer -->
            <div style="
              position: absolute;
              inset: -24px;
              background: radial-gradient(ellipse at 50% 50%, oklch(0.72 0.16 70 / 0.14) 0%, transparent 65%);
              filter: blur(8px);
              z-index: 0;
            "></div>

            <!-- Today's Deal Card -->
            <div class="relative z-10 rounded-2xl overflow-hidden animate-glow-pulse"
                 style="background: oklch(0.18 0.028 238); border: 1px solid oklch(0.72 0.16 70 / 0.30);">

              <!-- Card header -->
              <div class="flex items-center justify-between px-5 py-3.5 border-b" style="border-color: oklch(0.72 0.16 70 / 0.15);">
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-brand-500"></span>
                  <span class="text-xs font-semibold tracking-widest uppercase" style="color: oklch(0.78 0.14 70);">Today's Deal</span>
                </div>
                <span class="text-xs px-2.5 py-1 rounded-full font-medium" style="background: oklch(0.72 0.16 70 / 0.15); color: oklch(0.78 0.14 70);">✦ Best value</span>
              </div>

              <!-- Destination visual -->
              <div class="relative h-44 overflow-hidden" style="background: linear-gradient(145deg, oklch(0.18 0.05 245) 0%, oklch(0.14 0.04 255) 40%, oklch(0.20 0.06 230) 100%);">
                <!-- Destination silhouette / abstraction -->
                <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 100%; background: radial-gradient(ellipse at 60% 80%, oklch(0.35 0.08 245 / 0.5) 0%, transparent 55%), radial-gradient(ellipse at 20% 30%, oklch(0.72 0.16 70 / 0.12) 0%, transparent 40%);"></div>
                <!-- Skyline abstract shapes -->
                <svg viewBox="0 0 360 176" fill="none" xmlns="http://www.w3.org/2000/svg" class="absolute bottom-0 left-0 w-full" preserveAspectRatio="xMidYMax meet">
                  <!-- Distant mountains / hills -->
                  <path d="M0 176 L0 110 Q30 90 60 100 Q90 110 110 85 Q130 60 150 80 Q170 100 200 75 Q230 50 260 70 Q290 90 320 65 Q340 55 360 60 L360 176 Z" fill="oklch(0.22 0.04 240 / 0.7)"/>
                  <!-- Mid-ground architecture -->
                  <rect x="40" y="120" width="18" height="56" rx="1" fill="oklch(0.25 0.045 238)"/>
                  <rect x="62" y="105" width="24" height="71" rx="1" fill="oklch(0.23 0.042 239)"/>
                  <rect x="90" y="115" width="14" height="61" rx="1" fill="oklch(0.26 0.047 237)"/>
                  <rect x="108" y="98" width="30" height="78" rx="1" fill="oklch(0.22 0.040 240)"/>
                  <rect x="200" y="110" width="22" height="66" rx="1" fill="oklch(0.24 0.044 238)"/>
                  <rect x="226" y="95" width="16" height="81" rx="1" fill="oklch(0.23 0.043 239)"/>
                  <rect x="246" y="118" width="28" height="58" rx="1" fill="oklch(0.25 0.046 237)"/>
                  <rect x="290" y="105" width="20" height="71" rx="1" fill="oklch(0.22 0.041 240)"/>
                  <rect x="314" y="90" width="34" height="86" rx="1" fill="oklch(0.24 0.045 238)"/>
                  <!-- Lit windows -->
                  <rect x="67" y="112" width="4" height="4" rx="0.5" fill="oklch(0.72 0.16 70 / 0.8)"/>
                  <rect x="75" y="112" width="4" height="4" rx="0.5" fill="oklch(0.72 0.16 70 / 0.5)"/>
                  <rect x="67" y="122" width="4" height="4" rx="0.5" fill="oklch(0.72 0.16 70 / 0.6)"/>
                  <rect x="113" y="105" width="5" height="4" rx="0.5" fill="oklch(0.72 0.16 70 / 0.7)"/>
                  <rect x="122" y="105" width="5" height="4" rx="0.5" fill="oklch(0.72 0.16 70 / 0.4)"/>
                  <rect x="113" y="115" width="5" height="4" rx="0.5" fill="oklch(0.72 0.16 70 / 0.65)"/>
                  <rect x="230" y="103" width="4" height="4" rx="0.5" fill="oklch(0.72 0.16 70 / 0.75)"/>
                  <rect x="230" y="113" width="4" height="4" rx="0.5" fill="oklch(0.72 0.16 70 / 0.5)"/>
                  <rect x="318" y="98" width="5" height="5" rx="0.5" fill="oklch(0.72 0.16 70 / 0.8)"/>
                  <rect x="327" y="98" width="5" height="5" rx="0.5" fill="oklch(0.72 0.16 70 / 0.55)"/>
                  <!-- Stars -->
                  <circle cx="80" cy="30" r="1" fill="oklch(0.90 0.005 75 / 0.7)"/>
                  <circle cx="160" cy="20" r="1.2" fill="oklch(0.90 0.005 75 / 0.8)"/>
                  <circle cx="240" cy="35" r="0.8" fill="oklch(0.90 0.005 75 / 0.6)"/>
                  <circle cx="300" cy="18" r="1" fill="oklch(0.90 0.005 75 / 0.75)"/>
                  <circle cx="50" cy="45" r="0.7" fill="oklch(0.90 0.005 75 / 0.5)"/>
                  <!-- Moon -->
                  <circle cx="320" cy="30" r="10" fill="oklch(0.85 0.04 80 / 0.25)"/>
                  <circle cx="324" cy="28" r="8" fill="oklch(0.18 0.05 245 / 0.8)"/>
                </svg>
                <!-- Destination label -->
                <div class="absolute top-3 left-4">
                  <p class="text-xs font-medium" style="color: oklch(0.88 0.010 75 / 0.7);">Tonight's featured route</p>
                </div>
              </div>

              <!-- Card body -->
              <div class="px-5 py-4">
                <div class="flex items-start justify-between gap-3 mb-3">
                  <div>
                    <h3 class="font-display text-xl leading-tight" style="color: oklch(0.96 0.006 75); font-style: italic;">New York → Tokyo</h3>
                    <p class="text-xs mt-0.5" style="color: oklch(0.65 0.018 235);">Business Class · Round-trip · Oct 2025</p>
                  </div>
                  <div class="text-right shrink-0">
                    <p class="text-2xl font-semibold leading-none" style="color: oklch(0.78 0.14 70);">62,500</p>
                    <p class="text-xs mt-0.5" style="color: oklch(0.65 0.018 235);">Chase UR pts</p>
                  </div>
                </div>

                <!-- Transfer path -->
                <div class="rounded-xl px-4 py-3 mb-4" style="background: oklch(0.22 0.030 237); border: 1px solid oklch(0.72 0.16 70 / 0.10);">
                  <p class="text-xs mb-2 font-medium" style="color: oklch(0.65 0.018 235);">Optimal transfer path:</p>
                  <div class="flex items-center gap-1.5 flex-wrap">
                    <span class="text-xs px-2 py-1 rounded font-medium" style="background: oklch(0.72 0.16 70 / 0.15); color: oklch(0.82 0.12 72);">Chase UR</span>
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M7 3l3 3-3 3" stroke="oklch(0.65 0.018 235)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span class="text-xs px-2 py-1 rounded font-medium" style="background: oklch(0.72 0.16 70 / 0.15); color: oklch(0.82 0.12 72);">ANA Miles</span>
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M7 3l3 3-3 3" stroke="oklch(0.65 0.018 235)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span class="text-xs px-2 py-1 rounded font-medium" style="background: oklch(0.26 0.04 240); color: oklch(0.88 0.010 75);">NH 008</span>
                    <span class="ml-auto text-xs font-semibold" style="color: oklch(0.72 0.14 68);">2.8¢/pt</span>
                  </div>
                </div>

                <!-- CTA inside card -->
                <a href="#cta" class="flex items-center justify-center gap-2 w-full py-3 rounded-xl text-sm font-semibold transition-all duration-200 hover:opacity-90"
                   style="background: oklch(0.72 0.16 70); color: oklch(0.13 0.025 240);">
                  Book this deal
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2.5 7h9M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </div>
            </div>

            <!-- Floating badge -->
            <div class="absolute -top-3 -right-3 z-20 px-3 py-1.5 rounded-full text-xs font-semibold shadow-lg"
                 style="background: oklch(0.26 0.04 240); border: 1px solid oklch(0.72 0.16 70 / 0.3); color: oklch(0.88 0.010 75);">
              ✦ Refreshes at midnight
            </div>
          </div>
        </div>

      </div><!-- /grid -->

      <!-- Social proof strip -->
      <div class="mt-20 pt-8 border-t border-surface-200/10 animate-fade-in delay-500">
        <div class="flex flex-wrap items-center gap-x-10 gap-y-4">
          <p class="text-xs font-medium uppercase tracking-widest" style="color: oklch(0.50 0.015 235);">Connects with</p>
          <div class="flex flex-wrap items-center gap-x-8 gap-y-3">
            {['Chase UR', 'Amex MR', 'Citi TYP', 'Delta SkyMiles', 'United MileagePlus', 'Hyatt', 'Marriott Bonvoy'].map(prog => (
              <span class="text-sm font-medium" style={`color: oklch(0.60 0.015 235);`}>{prog}</span>
            ))}
          </div>
        </div>
      </div>

    </div><!-- /container -->
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       STATS — Impact numbers
       ═══════════════════════════════════════════════════════════════════ -->
  <section style="background: oklch(0.16 0.026 239);">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { stat: '18+', label: 'loyalty programs connected' },
          { stat: '3.1¢', label: 'average value per point' },
          { stat: '1', label: 'curated deal per day, just for you' },
          { stat: '< 60s', label: 'from login to bookable deal' },
        ].map(({ stat, label }) => (
          <div class="text-center">
            <p class="font-display text-4xl sm:text-5xl mb-2" style="color: oklch(0.78 0.14 70); font-style: italic;">{stat}</p>
            <p class="text-sm leading-snug" style="color: oklch(0.60 0.015 235);">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       HOW IT WORKS — 3 steps
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="how-it-works" style="background: oklch(0.13 0.025 240);">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-24 md:py-32">

      <!-- Section header -->
      <div class="max-w-2xl mb-16">
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: oklch(0.72 0.14 70);">How Redeemly works</p>
        <h2 class="font-display text-4xl sm:text-5xl leading-tight" style="color: oklch(0.96 0.006 75); font-style: italic; font-weight: 400;">
          No searching.<br>Just your next trip.
        </h2>
        <p class="mt-5 text-base leading-relaxed" style="color: oklch(0.60 0.015 235); max-width: 42ch;">
          Every competitor makes you hunt. Redeemly does the work — reading your real balances and finding the best redemption in the market today.
        </p>
      </div>

      <!-- Steps -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {[
          {
            num: '01',
            title: 'Connect your accounts',
            body: 'Securely link your Chase, Amex, Citi, airline, and hotel accounts. Pointara reads your exact point balances in real time — no manual entry, no spreadsheets.',
            icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
          },
          {
            num: '02',
            title: 'We run the math',
            body: 'Our engine cross-references live award availability with every transfer partner ratio across your programs, calculating true cents-per-point value for thousands of routes.',
            icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>`,
          },
          {
            num: '03',
            title: 'Book one perfect deal',
            body: 'Each day, Pointara surfaces one deal — the highest-value route you can book right now with what you actually have. One tap takes you directly to the booking page.',
            icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>`,
          },
        ].map(({ num, title, body, icon }) => (
          <div class="relative rounded-2xl p-7 card-amber-glow transition-all duration-300"
               style="background: oklch(0.18 0.028 238);">
            <!-- Step number -->
            <p class="font-display text-6xl mb-6 leading-none select-none" style="color: oklch(0.72 0.16 70 / 0.12); font-style: italic;">{num}</p>
            <!-- Icon -->
            <div class="mb-4" style="color: oklch(0.78 0.14 70);" set:html={icon}></div>
            <h3 class="font-display text-xl mb-3" style="color: oklch(0.96 0.006 75); font-weight: 400;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: oklch(0.60 0.015 235);">{body}</p>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       FEATURE DEEP-DIVES — alternating left/right
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="features" style="background: oklch(0.15 0.027 239);">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-24 md:py-32 space-y-28">

      <!-- Feature 1: Transfer path optimizer -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Text -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: oklch(0.72 0.14 70);">Transfer path intelligence</p>
          <h2 class="font-display text-3xl sm:text-4xl leading-tight mb-5" style="color: oklch(0.96 0.006 75); font-style: italic; font-weight: 400;">
            The transfer math you'd never do yourself
          </h2>
          <p class="text-base leading-relaxed mb-6" style="color: oklch(0.60 0.015 235); max-width: 44ch;">
            Chase Ultimate Rewards alone transfers to 14 partners. Multiply that by your Amex and Citi balances and you have hundreds of possible paths to any flight. Pointara tests all of them — and shows you the one that yields the most value per point, per dollar of taxes.
          </p>
          <ul class="space-y-3">
            {[
              'Live partner transfer ratios updated daily',
              'Taxes + fees factored into true value calc',
              'Alerts when a transfer bonus boosts your deal',
              'Partner sweet-spot routing (e.g. ANA for JAL business)',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm" style="color: oklch(0.70 0.018 235);">
                <svg class="shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="8" r="7" stroke="oklch(0.72 0.16 70)" stroke-width="1"/>
                  <path d="M5 8l2 2 4-4" stroke="oklch(0.72 0.16 70)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <!-- Visual: transfer path UI mock -->
        <div class="rounded-2xl p-6 card-amber-glow" style="background: oklch(0.18 0.028 238);">
          <p class="text-xs font-semibold uppercase tracking-widest mb-5" style="color: oklch(0.65 0.018 235);">Pointara transfer analysis</p>
          <!-- Route rows -->
          {[
            { from: 'Chase UR → United', pts: '60,000', val: '1.5¢', note: 'Standard rate' },
            { from: 'Chase UR → ANA → Biz', pts: '55,000', val: '3.1¢', note: '✦ Recommended', highlight: true },
            { from: 'Amex MR → ANA', pts: '55,000', val: '2.8¢', note: 'Alt if UR low' },
            { from: 'Citi TYP → Turkish', pts: '45,000', val: '2.2¢', note: 'Economy only' },
          ].map(({ from, pts, val, note, highlight }) => (
            <div class={`flex items-center justify-between gap-3 px-4 py-3 rounded-xl mb-2 ${highlight ? 'border' : 'opacity-70'}`}
                 style={highlight ? `background: oklch(0.72 0.16 70 / 0.08); border-color: oklch(0.72 0.16 70 / 0.35);` : `background: oklch(0.22 0.030 237);`}>
              <div>
                <p class="text-sm font-medium" style={`color: ${highlight ? 'oklch(0.88 0.010 75)' : 'oklch(0.70 0.018 235)'};`}>{from}</p>
                <p class="text-xs mt-0.5" style={`color: ${highlight ? 'oklch(0.78 0.14 70)' : 'oklch(0.50 0.015 235)'};`}>{note}</p>
              </div>
              <div class="text-right shrink-0">
                <p class="text-sm font-semibold" style={`color: ${highlight ? 'oklch(0.78 0.14 70)' : 'oklch(0.65 0.018 235)'};`}>{val}<span class="text-xs font-normal">/pt</span></p>
                <p class="text-xs" style="color: oklch(0.50 0.015 235);">{pts} pts</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Feature 2: Real balance sync -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Visual: balance dashboard mock -->
        <div class="order-2 lg:order-1 rounded-2xl p-6 card-amber-glow" style="background: oklch(0.18 0.028 238);">
          <p class="text-xs font-semibold uppercase tracking-widest mb-5" style="color: oklch(0.65 0.018 235);">Your live balance snapshot</p>
          {[
            { prog: 'Chase Ultimate Rewards', pts: '148,200', icon: '◈', pct: 78 },
            { prog: 'Amex Membership Rewards', pts: '92,400', icon: '◆', pct: 62 },
            { prog: 'Citi ThankYou Points', pts: '63,750', icon: '◇', pct: 45 },
            { prog: 'Delta SkyMiles', pts: '41,000', icon: '▲', pct: 30 },
