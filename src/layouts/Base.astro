---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Redeemly — Your Points, One Perfect Deal, Every Single Day",
  description = "Redeemly reads your exact loyalty balances across Chase, Amex, Citi, airlines, and hotels — runs the transfer math — and surfaces one curated, bookable award deal each day, personalised to what you actually hold."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0F1C2E" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Redeemly",
      "description": "Travel points optimizer that reads your exact loyalty balances and surfaces one personalized daily award deal — no searching required.",
      "applicationCategory": "TravelApplication",
      "url": "https://points-travel-deals.onrender.com",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-body antialiased" style="background-color: oklch(0.13 0.025 240); color: oklch(0.88 0.010 75);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
